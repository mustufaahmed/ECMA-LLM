{
  "name": "ecma-llm-server",
  "version": "0.1.0",
  "private": true,
  "description": "ECMA-LLM multi-agent e-commerce chatbot backend (MySQL + Qdrant + LangGraph + OpenAI)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "import:dataset": "tsx prisma/importThelookDataset.ts",
    "ingest": "tsx src/ingestion/indexPolicies.ts",
    "bootstrap": "npm run prisma:generate && npm run prisma:push && npm run seed && npm run import:dataset && npm run ingest",
    "eval:run": "tsx src/eval/runEval.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.24",
    "@langchain/google-genai": "^0.2.18",
    "@langchain/langgraph": "^0.2.28",
    "@langchain/openai": "^0.3.15",
    "@prisma/client": "^5.8.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "openai": "^6.34.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
