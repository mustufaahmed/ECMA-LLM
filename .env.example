# ---- Server ----
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ---- MySQL (Laragon default: root / empty password on localhost:3306) ----
# Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="mysql://root:@127.0.0.1:3306/ecma_llm"

# ---- Qdrant (docker-compose service on :6333) ----
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=policy_chunks
POLICY_EMBED_DIM=1536
POLICY_SIM_THRESHOLD=0.7

# ---- OpenAI (RAG only — fixed text-embedding-3-small for ingest + query) ----
OPENAI_API_KEY=

# TheLook users.id used when chat still references demo-user (default: 1)
DEMO_USER_ID=1

# ---- Pipeline ----
MAX_REFINEMENT_LOOPS=2
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=700
